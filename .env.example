# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── PayPal ─────────────────────────────────────────────────────────────────
# Client ID is safe to expose (used in the browser SDK)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
# Secret NEVER goes to the browser
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID
# Switch to https://api-m.paypal.com for production
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# ─── NOWPayments ────────────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=YOUR_NOWPAYMENTS_IPN_SECRET
# Your public URL where NOWPayments will POST webhook callbacks
NOWPAYMENTS_CALLBACK_URL=https://your-domain.com/api/webhooks/nowpayments

# ─── Nodemailer (Gmail example) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
# Use an App Password, NOT your Gmail password
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Digital Store <your-email@gmail.com>"

# ─── Encryption ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=YOUR_64_HEX_CHAR_AES256_KEY

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
